# Shopify Admin API credentials for catalog seeding
# DO NOT COMMIT .env — it is gitignored

# Your shop's *.myshopify.com domain (without https://)
# Example: hatfield-mccoy-dtf.myshopify.com
SHOPIFY_SHOP_DOMAIN=

# ─────────────────────────────────────────────────────────────────────────────
# AUTH — Pick ONE of the two options below:
# ─────────────────────────────────────────────────────────────────────────────

# OPTION A — Admin-created Custom App (simplest, if you created via Shopify
# admin → Settings → Apps and sales channels → Develop apps).
# The token is revealed once on the "API credentials" tab.
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTION B — Dev Dashboard app (client_credentials grant).
# The script exchanges these for a 24h admin API token automatically.
# Requires the app to be installed on the store and Admin API scopes configured.
SHOPIFY_ADMIN_CLIENT_ID=
SHOPIFY_ADMIN_CLIENT_SECRET=

# Optional — pin the API version. Defaults to 2025-01 if unset.
# SHOPIFY_API_VERSION=2025-01

# Public Storefront token injected into runtime config during `npm run build`.
SHOPIFY_STOREFRONT_PUBLIC_TOKEN=

# Canonical production domain written into runtime config during `npm run build`.
SITE_URL_PRODUCTION=https://www.hatfieldmccoydtf.com
